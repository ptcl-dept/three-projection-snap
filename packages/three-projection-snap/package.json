{
  "name": "three-projection-snap",
  "version": "0.1.0",
  "description": "Screen-space vertex snapping for Three.js materials.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ptcl-dept/three-projection-snap.git",
    "directory": "packages/three-projection-snap"
  },
  "bugs": {
    "url": "https://github.com/ptcl-dept/three-projection-snap/issues"
  },
  "homepage": "https://github.com/ptcl-dept/three-projection-snap#readme",
  "keywords": [
    "three",
    "threejs",
    "webgl",
    "shader",
    "vertex",
    "projection",
    "snapping"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "prepublishOnly": "npm test",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "peerDependencies": {
    "three": ">=0.160.0"
  },
  "devDependencies": {
    "@types/three": "^0.160.0",
    "three": "^0.160.0"
  }
}
